{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2015",
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "rootDir": ".",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@frontend/*": ["./src/*"]
    },
    "outDir": "./dist"
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "test/mock-game-data.ts"],
  "references": [{ "path": "../shared" }]
}
