{
  "name": "codenames-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:all": "npx tsc --build",
    "clean:all": "rimraf **/dist",
    "test:all": "npm run test --workspaces",
    "dev:all": "npm run dev -w backend & npm run dev -w frontend",
    "test:e2e": "npx playwright test --config=frontend/test/e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^8.49.0",
    "jest": "^29.7.0",
    "kysely-codegen": "^0.20.0",
    "pg": "^8.13.3",
    "prettier": "^3.0.2",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "kysely": "0.28.17",
    "typecheck": "^0.1.2",
    "vite": "8.0.8",
    "winston-daily-rotate-file": "^5.0.0",
    "zustand": "^5.0.7"
  }
}
