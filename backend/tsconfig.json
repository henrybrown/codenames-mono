{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": ".",
    "module": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@backend/*": ["./src/*"],
      "@backend/test/*": ["./test/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist", "src/zzz-legacy/**"],
  "references": [{ "path": "../shared" }]
}
